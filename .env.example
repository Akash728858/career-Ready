# Career Platform - Environment Variables
# Copy to .env and fill in values

PORT=5000
NODE_ENV=development

# JWT Secret - Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database (SQLite - file path)
DATABASE_PATH=./career_platform.db

# Frontend (create frontend/.env — used by Vite at build/dev time)
# Use when the React app is not served from the same origin as /api (omit if using npm run dev + proxy)
# VITE_API_URL=http://localhost:5000

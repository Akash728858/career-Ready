{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/public",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/sql.js/dist/**"
    }
  }
}
